{
  "name": "farmon",
  "version": "0.1.1",
  "description": "AI-powered React coding assistant that edits your codebase through deterministic code transformations.",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "NODE_ENV=development tsx server/run.ts",
    "build": "npm run build:server && npm run build:ui && chmod +x dist/bin/farmon.js",
    "ui": "NODE_ENV=development vite --config ui/vite.config.ts",
    "build:server": "tsc -p tsconfig.server.json",
    "build:ui": "vite build --config ui/vite.config.ts",
    "test": "NODE_ENV=development node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "testrough": "NODE_ENV=development npx --inspect tsx tests/testrough.ts",
    "test:watch": "NODE_ENV=development node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:integration": "npm test -- tests/integration",
    "test:unit": "npm test -- tests/unit"
  },
  "bin": {
    "farmon": "./dist/bin/farmon.js"
  },
  "engines": {
    "node": ">=22"
  },
  "author": "Sarvpriy Arya sarvpriy.arya@gmail.com",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sarvpriy/farmon.git"
  },
  "homepage": "https://farmon.ai",
  "bugs": {
    "url": "https://github.com/sarvpriy/farmon/issues"
  },
  "dependencies": {
    "@babel/parser": "^7.28.0",
    "@babel/traverse": "^7.28.0",
    "@headlessui/react": "^2.2.10",
    "@tailwindcss/vite": "^4.3.1",
    "ajv": "^8.20.0",
    "commander": "^15.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^5.1.0",
    "http-proxy-middleware": "^3.0.7",
    "jsonpath": "^1.3.0",
    "lucide-react": "^1.21.0",
    "module-alias": "^2.3.4",
    "postcss-safe-parser": "^7.0.1",
    "prettier": "^3.8.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-icons": "^5.6.0",
    "synckit": "^0.11.13",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@eslint/js": "^10.0.1",
    "@rolldown/plugin-babel": "^0.2.3",
    "@types/babel__core": "^7.20.5",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.7.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jest": "^30.4.2",
    "nodemon": "^3.1.10",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.1",
    "ts-jest": "^29.4.11",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vite-tsconfig-paths": "^6.1.1"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "keywords": [
    "ai",
    "llm",
    "react",
    "reactjs",
    "developer-tools",
    "code-generation",
    "code-transformation",
    "ast",
    "refactoring",
    "automation",
    "frontend",
    "javascript",
    "typescript",
    "vite",
    "ollama",
    "agent",
    "ai-agent",
    "coding-assistant"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ]
}
